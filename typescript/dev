    # Clear previous error log
    > "$TEMP_ERROR_FILE"

    # Run linting and capture errors
    npm run lint 2>&1 | tee "$TEMP_ERROR_FILE"
    local exit_code=${PIPESTATUS[0]}

    # Check if we have errors (non-zero exit or error content) and AI is enabled
    if [[ $exit_code -ne 0 ]] || [[ -s "$TEMP_ERROR_FILE" && $(grep -i "error\|fail\|npm error" "$TEMP_ERROR_FILE") ]]; then
        if [[ "$AI_ENABLED" == "true" ]]; then
            echo ""
            echo -e "${YELLOW}❗ Linting errors detected. Would you like AI analysis? (Y/n):${NC} "
            read -r want_ai

            if [[ ! "$want_ai" =~ ^[Nn]$ ]]; then
                analyze_error_with_ai "$(cat "$TEMP_ERROR_FILE")" "LINT_ERROR"
            fi
        fi
        echo ""
        echo -e "${RED}❌ Linting failed!${NC}"
