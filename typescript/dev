#!/bin/bash

# This script now runs the Rust-based dev-cli

# Set the path to the dev-cli executable
DEV_CLI_PATH="../dev-cli/target/debug/dev"

# Check if the executable exists
if [ ! -f "$DEV_CLI_PATH" ]; then
    echo "Error: dev-cli executable not found at $DEV_CLI_PATH"
    echo "Please run 'cargo build' in the dev-cli directory first."
    exit 1
fi

# Run the dev-cli with all arguments passed to this script
"$DEV_CLI_PATH" "$@"
