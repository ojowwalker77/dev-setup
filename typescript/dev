# Function to run type check with AI error analysis
run_type_check() {
    echo -e "${BLUE}🔧 Running TypeScript type check...${NC}"

    # Clear previous error log
    > "$TEMP_ERROR_FILE"

    # Run type check and capture errors
    npm run type-check 2>&1 | tee "$TEMP_ERROR_FILE"
    local exit_code=${PIPESTATUS[0]}

    # Check if we have errors (non-zero exit or error content) and AI is enabled
    if [[ $exit_code -ne 0 ]] || [[ -s "$TEMP_ERROR_FILE" && $(grep -i "error\|fail\|npm error" "$TEMP_ERROR_FILE") ]]; then
        if [[ "$AI_ENABLED" == "true" ]]; then
            echo ""
            echo -e "${YELLOW}❗ Type errors detected. Would you like AI analysis? (Y/n):${NC} "
            read -r want_ai

            if [[ ! "$want_ai" =~ ^[Nn]$ ]]; then
                analyze_error_with_ai "$(cat "$TEMP_ERROR_FILE")" "TYPE_ERROR"
            fi
        fi
        echo ""
        echo -e "${RED}❌ Type check failed!${NC}"
        return $exit_code
    fi
}

# AI Debug Mode - analyze recent errors
ai_debug_mode() {
    echo -e "${PURPLE}🤖 AI Debug Mode${NC}"
    echo -e "${PURPLE}===============${NC}"
    echo ""

    if [[ ! -f "$TEMP_ERROR_FILE" ]] || [[ ! -s "$TEMP_ERROR_FILE" ]]; then
        echo -e "${YELLOW}No recent errors found. Try running a build, lint, or type check first.${NC}"
        echo ""
        return
    fi

    echo -e "${CYAN}Recent errors found. Analyzing with AI...${NC}"
    analyze_error_with_ai "$(cat "$TEMP_ERROR_FILE")" "DEBUG_SESSION"
}

# Load configuration on startup
load_config

# Main loop
while true; do
    show_menu
    read -r choice

    case $choice in
        1)
            start_dev_server
            break
            ;;
        2)
            if run_build_check; then
                echo ""
                echo -e "${GREEN}✅ Build check completed!${NC}"
                echo ""
            else
                echo ""
            fi
            ;;
        3)
            if commit_and_push; then
                echo ""
                echo -e "${GREEN}✅ Push completed!${NC}"
                echo ""
            else
                echo ""
            fi
            ;;
        4)
            if run_lint; then
                echo ""
                echo -e "${GREEN}✅ Linting completed!${NC}"
                echo ""
            else
                echo ""
            fi
            ;;
        5)
            if run_type_check; then
                echo ""
                echo -e "${GREEN}✅ Type check completed!${NC}"
                echo ""
            else
                echo ""
            fi
            ;;
        6)
            if [[ "$AI_ENABLED" == "true" ]]; then
                ai_debug_mode
            else
                setup_ai
            fi
            ;;
        7)
            if [[ "$AI_ENABLED" == "true" ]]; then
                setup_ai
            else
                echo -e "${YELLOW}⚠️  AI Debug Mode requires setup first. Please choose option 6 to configure Gemini.${NC}"
                echo ""
            fi
            ;;
        8)
            echo -e "${BLUE}👋 Goodbye!${NC}"
            exit 0
            ;;
        *)
            echo -e "${RED}❌ Invalid option. Please choose 1-8.${NC}"
            echo ""
            ;;
    esac
done